DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id
CLIENT_SECRET=your_discord_client_secret
GUILD_ID=your_guild_id

DATABASE_URL=file:./koesu.db
DATABASE_TYPE=sqlite

REDIS_URL=redis://localhost:6379
REDIS_MODE=memory

LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=your_lavalink_password
LAVALINK_SECURE=false
LAVALINK_YTDLP_HOST=172.17.0.1

RPC_PORT=3000
RPC_REDIRECT_URI=http://your_server_ip:3000

LASTFM_API_KEY=
LASTFM_API_SECRET=

YOUTUBE_API_KEY=your_youtube_api_key

YTDLP_HOST=localhost
YTDLP_SERVER_PORT=7331

KOESU_HTTP_HOST=localhost
KOESU_HTTP_PORT=7332

MUSIC_DIR=/root/musica
CACHE_DIR=./cache/audio
CACHE_MAX_MB=500

DJ_AI_API_KEY=your_groq_api_key
DJ_AI_API_URL=https://api.groq.com/openai/v1
DJ_AI_MODEL=llama-3.3-70b-versatile
DJ_SEARCH_ENGINE=duckduckgo
DJ_TTS_VOICE=troy
DJ_TTS_MODEL=canopylabs/orpheus-v1-english
